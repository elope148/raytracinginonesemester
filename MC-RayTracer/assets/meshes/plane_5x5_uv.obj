# 5m x 5m plane (XY plane, Z=0, centered at origin, with UV coords 0-1)
# Use material uv_scale to control tiling frequency.
o Plane_5x5_UV
# vertices (x, y, z)
v -2.5 -2.5 0.0
v  2.5 -2.5 0.0
v  2.5  2.5 0.0
v -2.5  2.5 0.0
# normals (pointing up, +Z)
vn 0.0 0.0 1.0
# texture coordinates (0-1 across full plane; multiply by uv_scale to tile)
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
# faces (vertex/uv/normal)
f 1/1/1 2/2/1 3/3/1
f 1/1/1 3/3/1 4/4/1
